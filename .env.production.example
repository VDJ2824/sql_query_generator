# Public web origin
PUBLIC_ORIGIN=
VITE_API_BASE_URL=/api

# MongoDB: use the included mongo container or MongoDB Atlas.
# Container example: mongodb://mongo:27017/sql-query-generator
MONGODB_URI=

# Express authentication and internal service gateway
JWT_SECRET=
SQL_SERVICE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# PostgreSQL bootstrap superuser is used only by the container init process.
POSTGRES_BOOTSTRAP_DB=
POSTGRES_BOOTSTRAP_USER=
POSTGRES_BOOTSTRAP_PASSWORD=

# PostgreSQL restricted application account for normal SQL execution.
POSTGRES_APP_DB=
POSTGRES_APP_USER=
POSTGRES_APP_PASSWORD=
POSTGRES_APP_URL=

# PostgreSQL privileged account for allow-listed admin DDL only.
POSTGRES_ADMIN_USER=
POSTGRES_ADMIN_PASSWORD=
POSTGRES_ADMIN_URL=

# MySQL root is used only by the container init process.
MYSQL_ROOT_PASSWORD=

# MySQL restricted application account for normal SQL execution.
MYSQL_APP_DATABASE=
MYSQL_APP_USER=
MYSQL_APP_PASSWORD=
MYSQL_APP_URL=

# MySQL privileged account for allow-listed admin DDL only.
MYSQL_ADMIN_USER=
MYSQL_ADMIN_PASSWORD=
MYSQL_ADMIN_URL=

# Optional SQLite path for demo-only target connections.
SQLITE_DEMO_PATH=
